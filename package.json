{
  "name": "sdcc-tests",
  "version": "0.0.0",
  "private": true,
  "description": "No-prod SDCC test and tooling workspace.",
  "scripts": {
    "dp-isolate-client": "vite --host 127.0.0.1 --config client/dp-isolate/vite.config.js",
    "dp-isolate-fixtures:capture": "node tools/dp-isolate-fixtures/capture.cjs",
    "dp-isolate-fixtures:help": "node tools/dp-isolate-fixtures/help.cjs",
    "dp-isolate-fixtures:list": "node tools/dp-isolate-fixtures/list.cjs",
    "dp-isolate-fixtures:restore": "node tools/dp-isolate-fixtures/restore.cjs",
    "dp-isolate-fixtures:restore-clean": "node tools/dp-isolate-fixtures/restore-clean.cjs",
    "gen-supervisor-fragments": "node tools/gen-supervisor-fragments.cjs",
    "playwright": "playwright",
    "test:dp-isolate": "playwright test tests/dp-isolate",
    "test:dp-isolate:api": "playwright test tests/dp-isolate/dp-isolate-api.spec.cjs",
    "test:dp-isolate:api-short": "playwright test tests/dp-isolate/dp-isolate-api-short.spec.cjs",
